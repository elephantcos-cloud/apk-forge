<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔨 Start a Build"
            android:textColor="@color/on_surface"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Owner -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_owner"
            android:layout_marginBottom="12dp"
            app:boxBackgroundColor="@color/surface_dark"
            app:boxStrokeColor="@color/forge_orange"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_owner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface"
                android:inputType="textNoSuggestions"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Repo -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_repo"
            android:layout_marginBottom="12dp"
            app:boxBackgroundColor="@color/surface_dark"
            app:boxStrokeColor="@color/forge_orange"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_repo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface"
                android:inputType="textNoSuggestions"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Repo info -->
        <TextView
            android:id="@+id/tv_repo_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_muted"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <!-- Branch Spinner -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Branch"
            android:textColor="@color/on_surface_muted"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <Spinner
            android:id="@+id/spinner_branch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/surface_elevated"
            android:layout_marginBottom="12dp"/>

        <!-- Workflow -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_workflow"
            android:layout_marginBottom="20dp"
            app:boxBackgroundColor="@color/surface_dark"
            app:boxStrokeColor="@color/forge_orange"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_workflow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface"
                android:text="build.yml"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Build Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_build"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_build"
            android:textSize="16sp"
            app:backgroundTint="@color/forge_orange"
            android:layout_marginBottom="8dp"/>

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_cancel"
            app:backgroundTint="@color/forge_red"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="@style/Widget.Material3.LinearProgressIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Status Text -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_ready"
            android:textColor="@color/on_surface_muted"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"/>

        <!-- Artifacts -->
        <TextView
            android:id="@+id/tv_artifacts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/forge_green"
            android:textSize="14sp"
            android:visibility="gone"
            android:background="@color/surface_elevated"
            android:padding="12dp"/>

    </LinearLayout>
</ScrollView>
